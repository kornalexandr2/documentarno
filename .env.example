# Documentarno Environment Variables Template

# PostgreSQL
POSTGRES_USER=doc_admin
POSTGRES_PASSWORD=change_me_documentarno_db_password
POSTGRES_DB=documentarno
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Ollama
OLLAMA_BASE_URL=http://ollama:11434

# Backend / Security
JWT_SECRET=change_me_generate_a_long_random_secret_before_start
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:8080

# Initial Superadmin User
FIRST_SUPERUSER=admin
FIRST_SUPERUSER_PASSWORD=change_me_initial_superadmin_password

# Paths (Absolute paths on host machine for Docker volumes)
DOC_SOURCE_PATH=./doc_source
DATA_PATH=./data
