# Whitelist-based .gitignore for Documentarno (as per spec.md)

# 1. Ignore EVERYTHING by default
*

# 2. Allow directory traversal (crucial for whitelist to work)
!*/

# 3. ROOT Whitelist
!.gitignore
!.env.example
!docker-compose.yml
!docker-compose.gpu.yml
!install.sh
!update.sh
!README.md
!requirements.txt

# 4. DIRECTORY Whitelist
!backend/**
!frontend/**
!nginx/**
!docs/**

# 5. HARD EXCLUDES (Required by spec.md)
# Forbidden to push: .env, data/, and DEVELOPE/
.env
data/
DEVELOPE/
backend/venv/
backend/.venv/
backend/__pycache__/
frontend/node_modules/
frontend/dist/
.DS_Store
Thumbs.db
*.pyc
*.log
